<!DOCTYPE html>
<html>

<head>

<title>Student Management System</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

<div class="container mt-4">

<h1 class="mb-4">Student Management System</h1>

<form action="/add" method="POST" class="mb-4">

<input name="name" placeholder="Name" class="form-control mb-2" required>

<input name="age" placeholder="Age" class="form-control mb-2" required>

<input name="roll" placeholder="Roll No" class="form-control mb-2" required>

<input name="branch" placeholder="Branch" class="form-control mb-2" required>

<button class="btn btn-primary">New Student</button>

</form>

<% students.forEach(student => { %>

<div class="card mb-3">

<div class="card-body">

<h4><%= student.name %></h4>

<p>Age: <%= student.age %></p>

<p>Roll No: <%= student.roll %></p>

<p>Branch: <%= student.branch %></p>

<hr>

<a href="/edit/<%= student._id %>" class="btn btn-primary">Edit</a>

<a href="/delete/<%= student._id %>" class="btn btn-danger">Delete</a>

</div>

</div>

<% }) %>

</div>

</body>

</html>