<!DOCTYPE html>
<html>

<head>

<title>Edit Student</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

<div class="container mt-4">

<h2>Edit Student</h2>

<form action="/update/<%= student._id %>" method="POST">

<input name="name" value="<%= student.name %>" class="form-control mb-2">

<input name="age" value="<%= student.age %>" class="form-control mb-2">

<input name="roll" value="<%= student.roll %>" class="form-control mb-2">

<input name="branch" value="<%= student.branch %>" class="form-control mb-3">

<button class="btn btn-success">Update</button>

</form>

</div>

</body>

</html>